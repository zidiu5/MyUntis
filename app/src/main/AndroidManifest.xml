<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ===== BERECHTIGUNGEN ===== -->

    <!-- Internet: Für API-Anfragen unbedingt notwendig -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Netzwerkstatus: Prüfen ob Internet verfügbar -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".MyUntisApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyUntis"
        android:networkSecurityConfig="@xml/network_security_config">

        <!--
            MainActivity: Die einzige Activity der App.
            Compose übernimmt die gesamte Navigation intern.

            android:windowSoftInputMode: Tastatur schiebt Layout nach oben
            android:exported: true = App kann vom Launcher gestartet werden
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.MyUntis.SplashScreen"
            android:windowSoftInputMode="adjustResize">

            <!-- Diese Activity ist der App-Einstiegspunkt -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>